<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.WeatherRadarWeatherRadarSensorMapper">
    <insert id="insertWeatherRadarWeatherRadarSensor" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.info.WeatherRadarWeatherRadarSensor">
        insert into weather_radar_weather_radar_sensor_ground_stay(sensor_id,polarization_description,max_sensing_distance,time_resolution)
        values (#{sensorId},#{polarizationDescription},#{maxSensingDistance},#{timeResolution})
    </insert>

    <delete id="deleteSensorById">
        delete
        from weather_radar_weather_radar_sensor_ground_stay
        where sensor_id = #{sensorId}
    </delete>

    <select id="getSensorInfoById"
            resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.WeatherRadarWeatherRadarSensor">
        select *
        from weather_radar_weather_radar_sensor_ground_stay
        where sensor_id = #{sensorId}
    </select>
    <select id="selectAllSensorId" resultType="java.lang.String">
        select sensor_id
        from weather_radar_weather_radar_sensor_ground_stay
    </select>
</mapper>