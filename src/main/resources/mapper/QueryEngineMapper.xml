        and end_time = #{endTime}
    </select>


    <select id="getSensorDeriveBySensorIdAndYear" resultMap="SensorDerive">
        select *
        from sensor_derive_one_year
        <if test="sensorId != null and sensorId.size() > 0">
            where
            sensor_id in
            <foreach collection="sensorId" index="index" item="sensorId" open="(" separator="," close=")">
                #{sensorId}
            </foreach>
            and
        </if>
        and start_time = #{startTime}
        and end_time = #{endTime}
    </select>

    <select id="getSensorInfoBySensorType" resultMap="sensorInfo">
        select *
        from sensor_info
        where sensor_type = #{sensorType}
    </select>

    <select id="getSensorDataFloatByConditions"
            resultType="org.cug.geodt.weibo.sos.pojo.sensor.data.SensorDataFloat">
        select
            sensor_id,
            obs_timestamp,
            metric_name,
            metric_value,
            srid,
            longitude,
            latitude
        from
            sensor_data_float
        where
            sensor_id in
            <foreach collection="sensorId" index="index" item="sensorId" open="(" separator="," close=")">
                #{sensorId}
            </foreach>
        <if test="startTime!=null">
            and obs_timestamp >= #{startTime}
        </if>
        <if test="endTime!=null">
            and obs_timestamp 	<![CDATA[ <= ]]> #{endTime}
        </if>
        <if test="metricName!=null">
            and metric_name 	= #{metricName}
        </if>
    </select>
    <select id="getSensorDataStringByConditions"
            resultType="org.cug.geodt.weibo.sos.pojo.sensor.data.SensorDataString">
        select
            sensor_id,
            obs_timestamp,
            metric_name,
            metric_value,
