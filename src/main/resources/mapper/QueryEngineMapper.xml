            sensor_id in
            <foreach collection="sensorId" index="index" item="sensorId" open="(" separator="," close=")">
                #{sensorId}
            </foreach>
            and
        </if>
        <if test="metricName != null">
            metric_name = #{metricName}
        and
        </if>
        start_time = #{startTime}
        and end_time = #{endTime}
    </select>
    <select id="getSensorDeriveByConditionsAndHour" resultType="org.cug.geodt.weibo.sos.pojo.SensorDerive">
