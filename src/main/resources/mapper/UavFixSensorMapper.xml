<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.UavFixSensorMapper">
    <insert id="insertUavFixSensor" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.info.UavFixSensor">
        insert into uav_fix_sensor_low_altitude_move (sensor_id,sample_response_time,detection_accuracy,sample_cycle)
        values (#{sensorId},#{sampleResponseTime},#{detectionAccuracy},#{sampleCycle})
    </insert>
    <delete id="deleteSensorById">
        delete
        from uav_fix_sensor_low_altitude_move
        where sensor_id = #{sensorId}
    </delete>
    <select id="getSensorInfoById" resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.UavFixSensor">
        select *
        from uav_fix_sensor_low_altitude_move
        where sensor_id = #{sensorId}
    </select>
    <select id="selectAllSensorId" resultType="java.lang.String">
        select sensor_id
        from uav_fix_sensor_low_altitude_move
    </select>
</mapper>