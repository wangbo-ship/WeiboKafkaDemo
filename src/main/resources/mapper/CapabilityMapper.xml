        <result column="offering_identifier" property="offeringIdentifier"/>
        <result column="offering_description" property="offeringDescription"/>
        <result column="offering_is_reference" property="offeringIsReference"/>
        <result column="offering_sampling_time_start" property="offeringSamplingTimeStart"/>
        <result column="offering_sampling_time_end" property="offeringSamplingTimeEnd"/>
        <result column="offering_result_time_start" property="offeringResultTimeStart"/>
        <result column="offering_result_time_end" property="offeringResultTimeEnd"/>

        <result column="procedure_id" property="procedureId"/>
