    </resultMap>
    <select id="getCapabilityInfoBySensorIdsV2" resultMap="getCapabilityInfoResultMapV2">
        SELECT
            dataset.dataset_id,
            dataset.dataset_type,
            dataset.observation_type,
            dataset.fk_platform_id as platform_id,
            offering.offering_id,
            offering.identifier AS offering_identifier,
            offering.NAME AS offering_name,
            offering.description AS offering_description,
            offering.is_reference AS offering_is_reference,
            offering.sampling_time_start AS offering_sampling_time_start,
            offering.sampling_time_end AS offering_sampling_time_end,
            offering.result_time_start AS offering_result_time_start,
            offering.result_time_end AS offering_result_time_end,
            PROCEDURE.procedure_id,
            PROCEDURE.identifier AS procedure_identifier,
            PROCEDURE.NAME AS procedure_name,
            PROCEDURE.description AS procedure_description,
            PROCEDURE.procedure_description_format,
            PROCEDURE.area AS procedure_area,
            feature_of_interest.feature_id,
            feature_of_interest.identifier AS feature_identifier,
            feature_of_interest.NAME AS feature_name,
            feature_of_interest.description AS feature_description,
            ST_AsText ( feature_of_interest.area ) AS feature_area,
            feature_of_interest.srid AS feature_srid,
            sensor_info.sensor_id,
            sensor_info.sensor_long_name,
            sensor_info.sensor_type,
            sensor_info.srid AS sensor_srid,
            sensor_info.sensor_longitude,
            sensor_info.sensor_latitude,
            sensor_info.sensor_install_time,
            sensor_info.create_user_id,
            sensor_info.metrics as sensor_metrics,
            sensor_info.sensor_length,
            sensor_info.sensor_width,
            sensor_info.sensor_height,
            sensor_info.sensor_weight,
            sensor_info.organisation_name,
--             sensor_info.individual_name,
            sensor_info.telephone,
            sensor_info.country,
            sensor_info.city,
            sensor_info.administrative_area,
            sensor_info.address,
            sensor_info.postal_code,
            sensor_info.email,
            sensor_info.datasource_id,
            sensor_info.datasource_type,
            sensor_info.obs_radius,
            sensor_info.fk_platform,
            sensor_info.data_format,
            sensor_info.arcrole,
            sensor_info.obs_theme,
            sensor_info.sample_duration,
            sensor_info.sample_interval,
            sensor_info.sensor_deploy_time,
            sensor_info.datasource_state,
            sensor_info.sensor_short_name,
            sensor_info.intend_application,
            sensor_info.equipment_manufacturer,
            sensor_info.description,
            sensor_info.fk_platform as platform_type
        FROM
            "dataset"
            JOIN offering ON dataset.fk_offering_id = offering.offering_id
            JOIN "procedure" ON dataset.fk_offering_id = "procedure".procedure_id
            JOIN feature_of_interest ON feature_of_interest.feature_id = dataset.fk_feature_id
            JOIN sensor_info ON sensor_info.sensor_id = dataset.fk_sensor_id
        <if test="sensorId != null and sensorId.size()>0">
            where dataset.fk_sensor_id in
            <foreach collection="sensorId" index="index" item="sensorId" open="(" separator="," close=")">
                #{sensorId}
            </foreach>
        </if>
    </select>




</mapper>