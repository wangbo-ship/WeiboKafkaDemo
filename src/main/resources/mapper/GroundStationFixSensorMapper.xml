<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.GroundStationFixSensorMapper">
    <insert id="insertGroundStationFixSensor">
        insert into ground_station_fix_sensor_ground_stay(sensor_id,sample_cycle,
                                    sample_response_time,detection_accuracy) values (#{sensorId},
                                  #{sampleCycle},#{sampleResponseTime}, #{detectionAccuracy})
    </insert>
    <delete id="deleteSensorById">
        delete
        from ground_station_fix_sensor_ground_stay
        where sensor_id = #{sensorId}
    </delete>
    <select id="getSensorInfoById" resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.GroundStationFixSensor">
        select *
        from ground_station_fix_sensor_ground_stay
        where sensor_id = #{sensorId}
    </select>
    <select id="selectAllSensorId" resultType="java.lang.String">
        select sensor_id
        from ground_station_fix_sensor_ground_stay
    </select>
</mapper>