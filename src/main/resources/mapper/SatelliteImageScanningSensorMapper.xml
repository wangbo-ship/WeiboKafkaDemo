<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.SatelliteImageScanningSensorMapper">
    <insert id="insertSatelliteImageScanningSensor" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.info.SatelliteImageScanningSensor">
        insert into satellite_image_type_scanning_sensor_medium_altitude_move(sensor_id,scanning_type,resolution,image_width,fov,side_angle,nadir_resolution)
        values (#{sensorId},#{scanningType},#{resolution},#{imageWidth},#{fov},#{sideAngle},#{nadirResolution})
    </insert>
    <delete id="deleteSensorById">
        delete
        from satellite_image_type_scanning_sensor_medium_altitude_move
        where sensor_id = #{sensorId}
    </delete>
    <select id="getSensorInfoById"
            resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.SatelliteImageScanningSensor">
        select *
        from satellite_image_type_scanning_sensor_medium_altitude_move
        where sensor_id = #{sensorId}
    </select>
    <select id="selectAllSensorId" resultType="java.lang.String">
        select sensor_id
        from satellite_image_type_scanning_sensor_medium_altitude_move
    </select>
</mapper>