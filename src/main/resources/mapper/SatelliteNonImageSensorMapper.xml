<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.SatelliteNonImageSensorMapper" >
    <insert id="insertSatelliteNonImageSensor" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.info.SatelliteNonImageSensor">
        insert into satellite_non_image_sensor_medium_altitude_move values (${sensorId});
    </insert>
    <delete id="deleteSensorById">
        delete
        from satellite_non_image_sensor_medium_altitude_move
        where sensor_id = #{sensorId}
    </delete>
    <select id="getSensorInfoById" resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.SatelliteNonImageSensor">
        select *
        from satellite_non_image_sensor_medium_altitude_move
        where sensor_id = #{sensorId}
    </select>
</mapper>