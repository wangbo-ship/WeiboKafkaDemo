<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.SatelliteImageRadarSensorMapper">
    <insert id="insertSatelliteImageRadarSensor" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.info.SatelliteImageRadarSensor">
        insert into satellite_image_type_radar_sensor_medium_altitude_move(sensor_id,resolution,image_width,min_band_frequency_range,max_band_frequency_range,polarization_type)
        values (#{sensorId},#{resolution},#{imageWidth},#{minBandFrequencyRange},#{maxBandFrequencyRange},#{polarizationType})
    </insert>
    <delete id="deleteSensorById">
        delete
        from satellite_image_type_radar_sensor_medium_altitude_move
        where sensor_id = #{sensorId}
    </delete>
    <select id="getSensorInfoById"
            resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.SatelliteImageRadarSensor">
        select *
        from satellite_image_type_radar_sensor_medium_altitude_move
        where sensor_id = #{sensorId}
    </select>
    <select id="selectAllSensorId" resultType="java.lang.String">
        select sensor_id
        from satellite_image_type_radar_sensor_medium_altitude_move
    </select>
</mapper>