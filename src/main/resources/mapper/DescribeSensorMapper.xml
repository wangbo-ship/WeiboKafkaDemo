<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.DescribeSensorMapper">

    <select id="getNewSensorInfoById" resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.SensorInfo">
        select * from sensor_info where sensor_id = #{sensor_id}
    </select>

    <select id="getGroundStationByPlatformId"
            resultType="org.cug.geodt.weibo.sos.pojo.sensor.platform.GroundStation">
        select * from ground_station where platform_id = #{platformId}
    </select>
    <select id="getUAVByPlatformId" resultType="org.cug.geodt.weibo.sos.pojo.sensor.platform.UAV">
        select * from uav where platform_id = #{platformId}
    </select>
    <select id="getSatelliteByPlatformId" resultType="org.cug.geodt.weibo.sos.pojo.sensor.platform.Satellite">
        select * from satllite where platform_id = #{platformId}
    </select>
</mapper>