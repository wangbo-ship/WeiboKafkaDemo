<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.UavRadarSensorMapper">

    <insert id="insertUavRadarSensor" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.info.UavRadarSensor">
        insert into uav_radar_sensor_low_altitude_move(sensor_id,min_band_frequency_range,max_band_frequency_range,
                wire_bundles_number,vertical_fov,horizontal_fov)
        values (#{sensorId},#{minBandFrequencyRange},#{maxBandFrequencyRange},
                #{wireBundlesNumber},#{verticalFov},
                #{horizontalFov})
    </insert>
    <delete id="deleteSensorById">
        delete
        from uav_radar_sensor_low_altitude_move
        where sensor_id = #{sensorId}
    </delete>
    <select id="getSensorInfoById" resultType="org.cug.geodt.weibo.sos.pojo.sensor.info.UavRadarSensor">
        select *
        from uav_radar_sensor_low_altitude_move
        where sensor_id = #{sensorId}
    </select>
    <select id="selectAllSensorId" resultType="java.lang.String">
        select sensor_id
        from uav_radar_sensor_low_altitude_move
    </select>

</mapper>