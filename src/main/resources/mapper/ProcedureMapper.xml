<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cug.geodt.weibo.sos.mapper.ProcedureMapper" >
    <insert id="insertProcedure" parameterType="org.cug.geodt.weibo.sos.pojo.sensor.sos.Procedures">
        insert into procedure(procedure_id,identifier,name,description,procedure_description_format,area)
        values (#{procedureId},#{identifier},#{name},#{description},#{procedureDescriptionFormat},
                #{area})
    </insert>
</mapper>